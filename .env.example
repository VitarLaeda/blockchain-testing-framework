# Copy to .env and adjust as needed. Do not commit real secrets.
# The caller's process environment always takes precedence over .env.

# Set REPORT_OPEN=true to launch `allure open` (a blocking HTTP server)
# after `npm run report`. Any other value only generates the static report.
REPORT_OPEN=true

# RPC_URL is ONLY used when running test/rpc/RpcClient.test.ts directly.
# `npm run test:rpc` builds a canonical URL from RPC_HOST/RPC_PORT and ignores
# any inherited RPC_URL, so you normally do not need to set this.
# RPC_URL=http://127.0.0.1:8545

# Optional overrides for the integration runner (loopback hosts only):
# RPC_HOST=127.0.0.1
# RPC_PORT=8545
# RPC_STARTUP_TIMEOUT_MS=30000
