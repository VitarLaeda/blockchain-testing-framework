{
  "all": true,
  "src": ["src"],
  "include": ["src/**/*.ts"],
  "exclude": ["**/*.d.ts", "test/**", "types/**"],
  "reporter": ["text", "text-summary", "html", "lcov"],
  "reports-dir": "coverage",
  "check-coverage": true,
  "lines": 90,
  "branches": 90,
  "functions": 90,
  "statements": 90
}
